# ─────────────────────────────────────────────────────────────
#  CréaVidéo — Variables d'environnement (modèle)
#  Copier ce fichier en .env.local et renseigner les valeurs.
#  .env.local n'est JAMAIS committé (cf. .gitignore).
# ─────────────────────────────────────────────────────────────

# Clé API Golpo AI (https://video.golpoai.com/api-docs)
# Laisser vide = mode mock (simulation locale)
GOLPO_API_KEY=

# URL de base de l'API Golpo (ne pas modifier)
GOLPO_API_URL=https://video.golpoai.com/api/v2

# Mode mock : "true" force le mock même si une clé est renseignée
NEXT_PUBLIC_MOCK_MODE=true

# ─────────────────────────────────────────────────────────────
#  Pipeline custom (OpenRouter + ElevenLabs + Kie.ai + ffmpeg)
#  Actif si OPENROUTER_API_KEY ET KIE_API_KEY sont définis,
#  et que Golpo n'est pas activé. ffmpeg doit être installé sur
#  la machine hôte (macOS : brew install ffmpeg).
# ─────────────────────────────────────────────────────────────

# OpenRouter — génération du script + storyboard (modèle Claude)
OPENROUTER_API_KEY=
# Modèle utilisé via OpenRouter (optionnel)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# URL du site, envoyée dans l'en-tête HTTP-Referer (optionnel)
OPENROUTER_SITE_URL=

# ElevenLabs — voix off française native (appel DIRECT, pas via Kie).
# Plan PAYANT requis pour les voix de la Voice Library via API.
ELEVENLABS_API_KEY=
# Modèle TTS (optionnel)
ELEVENLABS_MODEL=eleven_multilingual_v2
# IDs de voix ElevenLabs personnalisés (optionnels, sinon défauts intégrés)
ELEVENLABS_VOIX_FEMALE=
ELEVENLABS_VOIX_FEMALE_4=
ELEVENLABS_VOIX_MALE_3=
ELEVENLABS_VOIX_MALE_4=

# Kie.ai — illustrations (Flux-2) + musique de fond (Suno)
KIE_API_KEY=
# Modèles Kie.ai (optionnels)
KIE_IMAGE_MODEL=flux-2/pro-text-to-image
# Modèle Suno pour la musique de fond (V4, V4_5, V4_5PLUS, V5, V5_5)
KIE_SUNO_MODEL=V5

# Chemins ffmpeg/ffprobe personnalisés (optionnel, sinon pris dans le PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# Stockage des vidéos finales sur Supabase (optionnel).
# Sans ces variables, la vidéo est servie en local via /api/video/[jobId].
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
